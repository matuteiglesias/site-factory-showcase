# Public canonical URL used by links, smoke scripts, and checkout redirects.
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# Postgres-compatible database URL. Neon is the selected hosted path.
# Local dev may use: postgresql://site_factory:site_factory@localhost:5432/site_factory_dev?schema=public
# Vercel runtime should use the Neon pooled connection string with SSL when available.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB?sslmode=require"

# Basic-auth credentials protecting /admin, /api/admin, and /api/dev in production.
ADMIN_USER="change-me"
ADMIN_PASSWORD="change-me-long-random-password"

# Set to true only for internal/staging environments where the header ops link is acceptable.
NEXT_PUBLIC_SHOW_OPS_LINK="false"

# Mercado Pago production integration values. Keep unset until real MP is connected.
MP_ACCESS_TOKEN=""
MP_WEBHOOK_SECRET=""

# Optional internal notification sink for operational alerts.
INTERNAL_NOTIFICATION_WEBHOOK_URL=""
