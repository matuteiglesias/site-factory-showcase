{
  "name": "site-factory-showcase",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run verify:no-local-db && npm run typecheck && npm run lint && npm run test && npm run build",
    "smoke": "node scripts/smoke-local.mjs",
    "smoke:m1": "node scripts/smoke-m1.mjs",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "smoke:m2": "node scripts/smoke-m2.mjs",
    "postinstall": "prisma generate",
    "db:migrate:deploy": "prisma migrate deploy",
    "smoke:deploy": "node scripts/smoke-deployed.mjs",
    "verify:no-local-db": "node scripts/verify-no-local-db-tracked.mjs"
  },
  "dependencies": {
    "@prisma/client": "^6.19.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.22.0",
    "next": "16.2.9",
    "radix-ui": "^1.6.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.12.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "postcss": "^8.5.16",
    "prisma": "^6.19.0",
    "tailwindcss": "^4.3.1",
    "typescript": "^5",
    "vitest": "^4.1.9"
  }
}
